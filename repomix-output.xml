<file path="database.js">
const fs = require('fs');
const path = require('path');

// Ubicación de la base de datos portátil JSON
const dbPath = path.join(__dirname, 'productos.json');

/**
 * Carga los datos del archivo JSON local.
 * Si el archivo no existe, retorna una lista vacía.
 * @returns {Array} La lista de productos almacenados.
 */
function loadData() {
  try {
    if (fs.existsSync(dbPath)) {
      const content = fs.readFileSync(dbPath, 'utf8');
      return JSON.parse(content);
    }
  } catch (error) {
    console.error('Error al cargar la base de datos JSON:', error);
  }
  return [];
}

/**
 * Guarda la lista de productos en el archivo JSON.
 * @param {Array} data - La lista completa de productos.
 */
function saveData(data) {
  try {
    fs.writeFileSync(dbPath, JSON.stringify(data, null, 2), 'utf8');
  } catch (error) {
    console.error('Error al guardar la base de datos JSON:', error);
  }
}

/**
 * Inserta un producto o lo actualiza si el SKU ya existe (Simula UPSERT en SQLite)
 * @param {string} sku - ID único del producto (TEXT PRIMARY KEY)
 * @param {string} nombre - Nombre del producto (TEXT)
 * @param {number} precio - Precio único extraído del e-commerce (REAL)
 * @param {string} imagenUrl - URL de la imagen del producto (TEXT)
 * @returns {Object} Resultado de la operación compatible con SQLite run()
 */
function upsertProduct(sku, nombre, precio, imagenUrl) {
  const data = loadData();
  const existingIndex = data.findIndex(p => p.sku === sku);
  
  // Obtener la fecha local formateada estilo SQLite (YYYY-MM-DD HH:MM:SS)
  const now = new Date();
  const year = now.getFullYear();
  const month = String(now.getMonth() + 1).padStart(2, '0');
  const day = String(now.getDate()).padStart(2, '0');
  const hours = String(now.getHours()).padStart(2, '0');
  const minutes = String(now.getMinutes()).padStart(2, '0');
  const seconds = String(now.getSeconds()).padStart(2, '0');
  const ultimaActualizacion = `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;

  const product = {
    sku,
    nombre,
    precio: precio,
    imagen_url: imagenUrl,
    ultima_actualizacion: ultimaActualizacion
  };

  if (existingIndex !== -1) {
    // Si existe, actualizamos los valores (UPDATE)
    data[existingIndex] = product;
  } else {
    // Si no existe, lo insertamos (INSERT)
    data.push(product);
  }

  saveData(data);
  return { changes: 1 };
}

/**
 * Obtiene todos los productos del archivo
 * Ordenados por la fecha de última actualización (más recientes primero)
 * @returns {Array} Lista ordenada de productos
 */
function getAllProducts() {
  const data = loadData();
  // Ordenar descendente según la fecha
  return data.sort((a, b) => {
    return new Date(b.ultima_actualizacion) - new Date(a.ultima_actualizacion);
  });
}

module.exports = {
  upsertProduct,
  getAllProducts
};
