            <tr>
              <td colspan="4" style="text-align:center;padding:2rem;color:var(--color-text-muted);">Cargando registros...</td>
            </tr>
          </tbody>
        </table>
      </section>

      <!-- Grid De Laptops (Cargado por HTMX) -->
      <section class="admin-table-section">
        <h2 class="admin-table-title">Catálogo Completo Registrado (Visualización Técnica)</h2>
        
        <!-- 
          - hx-get: Carga automática al iniciar la página.
          - hx-trigger: Se dispara al cargar ('load') la página.
          - hx-target: Inserta las tarjetas dentro de este div.
        -->
        <div id="tabla-productos" class="catalog-grid" hx-get="/api/productos" hx-trigger="load" hx-indicator="#loading-indicator">
          <div style="grid-column:1/-1;text-align:center;padding:3rem;color:var(--color-text-muted);">
            <div class="admin-spinner" style="margin: 0 auto 1rem;"></div>
            Cargando catálogo local...
          </div>
        </div>
      </section>
    </main>

  </div>

  <script src="/js/admin.js"></script>
</body>
