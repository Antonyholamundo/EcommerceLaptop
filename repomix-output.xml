// 3. Obtener productos relacionados
async function fetchRelatedProducts() {
  try {
    const response = await fetch('/api/productos/json');
    if (!response.ok) return;
    const all = await response.json();

    const brand = parseBrand(currentProduct.nombre);
    
    // Filtrar relacionados: misma marca o similar rango de precio, excluyendo el actual
    let related = all.filter(p => p.sku !== currentProduct.sku);
    
    const sameBrand = related.filter(p => parseBrand(p.nombre) === brand);
    
    if (sameBrand.length >= 4) {
      related = sameBrand;
    } else {
      // Si hay pocas de la misma marca, mezclamos con precio similar (+-20%)
      const priceMin = currentProduct.precio * 0.8;
      const priceMax = currentProduct.precio * 1.2;
      const similarPrice = related.filter(p => p.precio >= priceMin && p.precio <= priceMax);
      
      // Combinar y eliminar duplicados
      const combined = [...sameBrand, ...similarPrice];
      related = combined.filter((item, idx) => combined.findIndex(x => x.sku === item.sku) === idx);
    }

    // Tomar 8 aleatorios
    related = related.sort(() => 0.5 - Math.random()).slice(0, 8);

    if (related.length === 0) {
      relatedProductsGrid.innerHTML = '<p style="color:var(--text-secondary);">No hay productos relacionados disponibles.</p>';
      return;
    }

    // Renderizar
    relatedProductsGrid.innerHTML = related.map(p => {
      const formattedPrice = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(p.precio);
      const itemBrand = parseBrand(p.nombre);
      const fallbackSvg = `data:image/svg+xml;utf8,<svg class=%22laptop-placeholder-svg%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22currentColor%22 stroke-width=%221.2%22 xmlns=%22http://www.w3.org/2000/svg%22><path d=%22M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25%22 /></svg>`;
      
      const imgHtml = p.imagen_url ? 
        `<img src="${p.imagen_url}" alt="${p.nombre}" loading="lazy" onerror="this.src='${fallbackSvg}';this.onerror=null;">` : 
        `<div class="laptop-placeholder-svg" style="display:flex;align-items:center;justify-content:center;height:100%;width:100%;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" style="width:40px;height:40px;opacity:0.6;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" /></svg></div>`;

      return `
        <div class="grid-card" style="width:260px;margin-bottom:0;">
          <div class="card-image-wrapper">
            <span class="brand-badge">${itemBrand}</span>
            <a href="/product.html?sku=${p.sku}">${imgHtml}</a>
          </div>
          <div class="card-sku">${p.sku}</div>
          <h3 class="card-title" title="${p.nombre}">
            <a href="/product.html?sku=${p.sku}">${p.nombre}</a>
          </h3>
          <div class="card-price-row">
            <div class="card-price">${formattedPrice}</div>
          </div>
          <div class="card-actions-wrapper">
            <button class="btn-primary-cart" onclick="addToCart('${p.sku}', '${p.nombre.replace(/'/g, "\\'")}', ${p.precio}, '${p.imagen_url || ''}')">
              Agregar al carrito
            </button>
          </div>
        </div>
      `;
    }).join('');
  } catch (e) {
    console.error('Error fetching related products:', e);
  }
}

// 4. Configurar las Pestañas (Tabs)
function setupTabs() {
  const switchTab = (activeBtn, activePanel) => {
    [tabBtnSpecs, tabBtnReviews, tabBtnShipping].forEach(btn => btn.classList.remove('active'));
    [tabPanelSpecs, tabPanelReviews, tabPanelShipping].forEach(panel => panel.classList.remove('active'));

    activeBtn.classList.add('active');
    activePanel.classList.add('active');
  };

  tabBtnSpecs.addEventListener('click', () => switchTab(tabBtnSpecs, tabPanelSpecs));
  tabBtnReviews.addEventListener('click', () => switchTab(tabBtnReviews, tabPanelReviews));
  tabBtnShipping.addEventListener('click', () => switchTab(tabBtnShipping, tabPanelShipping));
}

// 5. Configurar selector de cantidad
function setupQuantityPicker() {
  btnQtyMinus.addEventListener('click', () => {
    if (currentQuantity > 1) {
      currentQuantity--;
      qtyInput.value = currentQuantity;
    }
  });

  btnQtyPlus.addEventListener('click', () => {
    currentQuantity++;
    qtyInput.value = currentQuantity;
  });
}

// 6. Botón de compartir URL
function setupShareButton() {
  btnShareProduct.addEventListener('click', () => {
    const url = window.location.href;
    navigator.clipboard.writeText(url).then(() => {
      window.showToast('¡Enlace copiado al portapapeles!');
    }).catch(err => {
      console.error('Error al copiar enlace:', err);
      // Fallback manual en caso de fallo o bloqueos del navegador
      const dummy = document.createElement('input');
      document.body.appendChild(dummy);
      dummy.value = url;
      dummy.select();
      document.execCommand('copy');
      document.body.removeChild(dummy);
      window.showToast('¡Enlace copiado al portapapeles!');
    });
  });
}

// 7. Render 404
function render404(message) {
  productDetailDisplay.style.display = 'block';
  productDetailDisplay.innerHTML = `
    <div class="empty-catalog-state" style="padding: 6rem 2rem;">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:56px;height:56px;color:var(--danger);opacity:0.8;">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      <h2 style="font-weight:700;margin-top:1rem;color:var(--text-primary);">${message}</h2>
      <p style="margin-bottom:1.5rem;">El SKU consultado puede estar inactivo o haber sido removido.</p>
      <a href="/" class="btn-checkout-drawer" style="padding:0.75rem 2rem;display:inline-block;width:auto;text-decoration:none;">← Volver al catálogo principal</a>
    </div>
  `;
  breadcrumbCurrent.textContent = 'Producto no disponible';
}

// Helper: Extraer Marca
function parseBrand(nombre) {
  const brandKeywords = ['Apple', 'HP', 'Lenovo', 'Dell', 'Dynabook', 'Quasad', 'Samsung', 'Asus', 'Acer', 'MSI'];
  const nameLower = (nombre || '').toLowerCase();
  for (const b of brandKeywords) {
    if (nameLower.includes(b.toLowerCase())) {
      return b;
    }
  }
  return 'Otros';
}

// Helper: Parsear especificaciones
function parseSpecs(nombre) {
  const lower = (nombre || '').toLowerCase();
  
  // Procesador
  let processor = 'Intel / AMD';
  if (lower.includes('i7') || lower.includes('intel i7') || lower.includes('core i7')) {
    processor = 'Intel Core i7';
  } else if (lower.includes('i5') || lower.includes('intel i5') || lower.includes('core i5')) {
    processor = 'Intel Core i5';
  } else if (lower.includes('i3') || lower.includes('intel i3') || lower.includes('core i3')) {
    processor = 'Intel Core i3';
  } else if (lower.includes('ultra 7') || lower.includes('core ultra 7')) {
    processor = 'Intel Core Ultra 7';
  } else if (lower.includes('ultra 5') || lower.includes('core ultra 5')) {
    processor = 'Intel Core Ultra 5';
  } else if (lower.includes('ryzen 7') || lower.includes('ryzen7')) {
    processor = 'AMD Ryzen 7';
  } else if (lower.includes('ryzen 5') || lower.includes('ryzen5')) {
    processor = 'AMD Ryzen 5';
  } else if (lower.includes('ryzen 3') || lower.includes('ryzen3')) {
    processor = 'AMD Ryzen 3';
  } else if (lower.includes('m1')) {
    processor = 'Apple M1';
  } else if (lower.includes('m2')) {
    processor = 'Apple M2';
  } else if (lower.includes('m3')) {
    processor = 'Apple M3';
  } else if (lower.includes('m4')) {
    processor = 'Apple M4';
  } else if (lower.includes('m5')) {
    processor = 'Apple M5';
  } else if (lower.includes('a18 pro')) {
    processor = 'Apple A18 Pro';
  }
  
  // RAM
  let ram = 'N/D';
  const ramMatches = [...lower.matchAll(/(\d+)\s*(gb|tb)\b/ig)];
  if (ramMatches.length > 0) {
    const gbValues = ramMatches.map(m => {
      let num = parseInt(m[1]);
      if (m[2].toLowerCase() === 'tb') num *= 1024;
      return { str: m[0].toUpperCase(), val: num };
    });
    gbValues.sort((a, b) => a.val - b.val);
    ram = gbValues[0].str;
  }
  
  // Storage
  let storage = 'N/D';
  const ssdMatch = lower.includes('ssd') || lower.includes('m.2');
  const ramMatchesForDisco = [...lower.matchAll(/(\d+)\s*(gb|tb)\b/ig)];
  if (ramMatchesForDisco.length > 1) {
    const gbValues = ramMatchesForDisco.map(m => {
      let num = parseInt(m[1]);
      if (m[2].toLowerCase() === 'tb') num *= 1024;
      return { str: m[0].toUpperCase(), val: num };
    });
    gbValues.sort((a, b) => a.val - b.val);
    storage = gbValues[1].str + (ssdMatch ? ' SSD' : '');
  } else {
    if (lower.includes('ssd') || lower.includes('m.2') || lower.includes('disco')) {
      const storageOnlyMatch = lower.match(/(\d+)\s*(gb|tb)\b/i);
      if (storageOnlyMatch) storage = storageOnlyMatch[0].toUpperCase() + ' SSD';
    }
  }

  // Pantalla
  let screen = 'N/D';
  const screenMatch = lower.match(/(\d+(?:\.\d+)?)\s*(inch|pulg|”|")/i);
  if (screenMatch) {
    screen = screenMatch[1] + '"';
  }

  // OS
  let os = 'Windows 11';
  if (lower.includes('macos') || lower.includes('mac os') || lower.includes('apple mac')) {
    os = 'macOS';
  } else if (lower.includes('freedos') || lower.includes('free dos') || lower.includes('free-dos')) {
    os = 'FreeDOS';
  } else if (lower.includes('win11-pro') || lower.includes('win11 pro') || lower.includes('w11-pro') || lower.includes('w11pro')) {
    os = 'Windows 11 Pro';
  }

  // Color
  let color = 'N/D';
  const colorKeywords = ['silver', 'gray', 'grey', 'blue', 'black', 'citrus', 'indigo', 'blush', 'plata', 'gris', 'negro', 'azul', 'luna gray', 'blue night', 'mystic-blue'];
  for (const ck of colorKeywords) {
    if (lower.includes(ck)) {
      color = ck.charAt(0).toUpperCase() + ck.slice(1);
      break;
    }
  }

  return { processor, ram, storage, screen, os, color };
}
