/**
 * admin.js — Lógica de panel admin de NoteStore Ecuador
 */

// 1. Obtener y renderizar la tabla con los 5 productos más recientemente actualizados
async function fetchLastProducts() {
  try {
    const response = await fetch('/api/productos/json');
    if (!response.ok) return;
    const products = await response.json();

    // Ordenar descendente por la fecha de última actualización
    products.sort((a, b) => {
      return new Date(b.ultima_actualizacion) - new Date(a.ultima_actualizacion);
    });

    const latest = products.slice(0, 5);
    const tbody = document.getElementById('last-products-tbody');
    
    if (latest.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="4" style="text-align:center;padding:2rem;color:var(--color-text-muted);">
            No hay productos registrados en el archivo productos.json.
          </td>
        </tr>
      `;
      return;
    }

    tbody.innerHTML = latest.map(p => {
      const formattedPrice = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(p.precio);
      return `
        <tr>
          <td class="sku">${p.sku}</td>
          <td style="color:#ffffff;">${p.nombre}</td>
          <td class="price">${formattedPrice}</td>
          <td>${p.ultima_actualizacion}</td>
        </tr>
      `;
    }).join('');
  } catch (error) {
    console.error('Error al cargar últimos productos actualizados:', error);
  }
}

// 2. Proteger la ruta a nivel cliente en caso de que alguien acceda directo a /admin.html
function verifyKey() {
  const urlParams = new URLSearchParams(window.location.search);
  const key = urlParams.get('key');
  if (key !== 'admin2026') {
    // Redirigir a la tienda principal
    window.location.href = '/';
  }
}

// Inicialización
document.addEventListener('DOMContentLoaded', () => {
  verifyKey();
  fetchLastProducts();
});

// Registrar un listener para que HTMX recargue los 5 productos de la tabla al finalizar el scraping
document.body.addEventListener('htmx:afterOnLoad', () => {
  console.log('HTMX cargado exitosamente. Recargando tabla de últimos sincronizados...');
  fetchLastProducts();
});
</file>

