@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

/* ==========================================
   Variables de Diseño y Resets
   ========================================== */
:root {
  --bg-main: #FFFFFF;
  --bg-secondary: #F8F9FA;
  --accent: #223797;
  --accent-hover: #0052CC;
  --text-primary: #111111;
  --text-secondary: #6B7280;
  --border-color: #ffffff;
  --success: #16A34A;
  --danger: #DC2626;
  --badge-bg: #EFF6FF;
  --badge-text: #0066FF;
  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.06), 0 1px 2px rgba(0, 0, 0, 0.03);
  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.03);
  --radius-sm: 6px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  --font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background-color: var(--bg-main);
  color: var(--text-primary);
  font-family: var(--font-family);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  line-height: 1.5;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

a {
  color: inherit;
  text-decoration: none;
  transition: var(--transition);
}

button,
input,
select {
  font-family: inherit;
  font-size: inherit;
  color: inherit;
  border: none;
  background: none;
  outline: none;
}

/* Scrollbar moderno */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: var(--bg-secondary);
}

::-webkit-scrollbar-thumb {
  background: #D1D5DB;
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: #9CA3AF;
}

/* ==========================================
   Componente: Header Fijo
   ========================================== */
.header-sticky {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--border-color);
  box-shadow: var(--shadow-sm);
}

.header-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0.75rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
}

.logo-link {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-weight: 700;
  font-size: 1.35rem;
  color: var(--text-primary);
  letter-spacing: -0.5px;
}

.logo-link svg {
  width: 28px;
  height: 28px;
  color: var(--accent);
}

.logo-accent {
  color: var(--accent);
}

/* Barra de Búsqueda */
.search-wrapper {
  flex: 1;
  max-width: 600px;
  position: relative;
}

.search-input-container {
  display: flex;
  align-items: center;
  background-color: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 50px;
  padding: 0.5rem 1.25rem;
  transition: var(--transition);
}

.search-input-container:focus-within {
  border-color: var(--accent);
  background-color: var(--bg-main);
  box-shadow: 0 0 0 3px rgba(0, 102, 255, 0.1);
}

.search-input-container svg {
  width: 18px;
  height: 18px;
  color: var(--text-secondary);
  margin-right: 0.75rem;
}

.search-input {
  width: 100%;
  font-size: 0.9rem;
  background: transparent;
}

.search-input::placeholder {
  color: var(--text-secondary);
}

/* Controles Derecha */
.header-actions {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.cart-toggle-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background-color: var(--bg-secondary);
  border: 1px solid var(--border-color);
  cursor: pointer;
  transition: var(--transition);
}

.cart-toggle-btn:hover {
  background-color: var(--badge-bg);
  border-color: var(--accent);
}

.cart-toggle-btn svg {
  width: 20px;
  height: 20px;
  color: var(--accent);
}

.cart-count-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  background-color: var(--accent);
  color: #FFFFFF;
  font-size: 0.7rem;
  font-weight: 700;
  min-width: 20px;
  height: 20px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
  border: 2px solid #FFFFFF;
  transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.cart-count-badge.animate {
  transform: scale(1.3);
}

/* ==========================================
   Componente: Hero Banner
   ========================================== */
.hero-banner {
  background-color: var(--accent);
  color: #FFFFFF;
  padding: 2rem 1.5rem;
  text-align: left;
  position: relative;
  overflow: hidden;
  height: 180px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero-container {
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
}

.hero-status-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  background-color: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(4px);
  padding: 0.3rem 0.75rem;
  border-radius: 50px;
  font-size: 0.75rem;
  font-weight: 600;
  margin-bottom: 0.75rem;
}

.hero-status-dot {
  width: 6px;
  height: 6px;
  background-color: #4ADE80;
  border-radius: 50%;
  animation: pulse 1.5s infinite;
}

.hero-title {
  font-size: 1.8rem;
  font-weight: 700;
  margin-bottom: 0.25rem;
  letter-spacing: -0.5px;
}

.hero-subtitle {
  font-size: 0.95rem;
  opacity: 0.9;
  font-weight: 400;
}

/* ==========================================
   Layout Principal (Catálogo)
   ========================================== */
.main-layout {
  max-width: 1200px;
  margin: 2rem auto;
  padding: 0 1.5rem;
  width: 100%;
  flex: 1;
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 2rem;
}

/* ==========================================
   Sidebar: Filtros
   ========================================== */
.filter-sidebar {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.filter-section {
  border-bottom: 1px solid var(--border-color);
  padding-bottom: 1.25rem;
}

.filter-title-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  padding: 0.25rem 0;
  font-weight: 600;
  font-size: 0.95rem;
}

.filter-title-container svg {
  width: 16px;
  height: 16px;
  color: var(--text-secondary);
  transition: transform 0.2s ease;
}

.filter-title-container.collapsed svg {
  transform: rotate(-90deg);
}

.filter-content {
  margin-top: 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  transition: max-height 0.2s ease, opacity 0.2s ease;
}

.filter-content.hidden {
  display: none;
}

/* Inputs de Checkbox */
.checkbox-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 0.85rem;
  color: var(--text-secondary);
  cursor: pointer;
  user-select: none;
}

.checkbox-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.checkbox-label input {
  appearance: none;
  width: 16px;
  height: 16px;
  border: 1px solid var(--border-color);
  border-radius: 4px;
  cursor: pointer;
  position: relative;
  background-color: var(--bg-secondary);
  transition: var(--transition);
}

.checkbox-label input:checked {
  background-color: var(--accent);
  border-color: var(--accent);
}

.checkbox-label input:checked::after {
  content: "";
  position: absolute;
  left: 5px;
  top: 2px;
  width: 4px;
  height: 8px;
  border: solid white;
  border-width: 0 2px 2px 0;
  transform: rotate(45deg);
}

.brand-count {
  font-size: 0.75rem;
  color: var(--text-secondary);
  opacity: 0.7;
}

/* Slider de Precios */
.price-slider-container {
  padding: 0.5rem 0.25rem;
}

.slider-track-wrapper {
  position: relative;
  height: 6px;
  background-color: var(--border-color);
  border-radius: 3px;
  margin-bottom: 1.5rem;
}

.slider-track-highlight {
  position: absolute;
  height: 100%;
  background-color: var(--accent);
  border-radius: 3px;
}

.slider-thumb {
  position: absolute;
  top: 50%;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background-color: #FFFFFF;
  border: 2px solid var(--accent);
  cursor: pointer;
  transform: translate(-50%, -50%);
  box-shadow: var(--shadow-sm);
  z-index: 2;
}

.price-inputs-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
  align-items: center;
}

.price-input-box {
  display: flex;
  align-items: center;
  background-color: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  padding: 0.4rem 0.6rem;
  font-size: 0.85rem;
}

.price-input-box span {
  color: var(--text-secondary);
  margin-right: 0.25rem;
}

.price-input-box input {
  width: 100%;
  background: transparent;
  font-weight: 500;
}

/* Radio buttons Ordenar */
.radio-label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  color: var(--text-secondary);
  cursor: pointer;
}

.radio-label input {
  appearance: none;
  width: 16px;
  height: 16px;
  border: 1px solid var(--border-color);
  border-radius: 50%;
  cursor: pointer;
  position: relative;
  background-color: var(--bg-secondary);
  transition: var(--transition);
}

.radio-label input:checked {
  border-color: var(--accent);
}

.radio-label input:checked::after {
  content: "";
  position: absolute;
  left: 4px;
  top: 4px;
  width: 6px;
  height: 6px;
  background-color: var(--accent);
  border-radius: 50%;
}

.btn-outline-clear {
  width: 100%;
  padding: 0.6rem;
  border: 1px solid var(--accent);
  color: var(--accent);
  border-radius: var(--radius-sm);
  font-weight: 600;
  font-size: 0.85rem;
  cursor: pointer;
  text-align: center;
  transition: var(--transition);
  margin-top: 1rem;
}

.btn-outline-clear:hover {
  background-color: var(--badge-bg);
}

/* ==========================================
   Área de Catálogo y Controles Superiores
   ========================================== */
.catalog-container {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.catalog-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.9rem;
  color: var(--text-secondary);
}

.products-found-text {
  font-weight: 500;
  color: var(--text-primary);
}

.catalog-controls-right {
  display: flex;
  align-items: center;
  gap: 1.25rem;
}

.view-toggle-group {
  display: flex;
  background-color: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  padding: 2px;
}

.view-toggle-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: 4px;
  cursor: pointer;
  color: var(--text-secondary);
  transition: var(--transition);
}

.view-toggle-btn.active {
  background-color: #FFFFFF;
  color: var(--accent);
  box-shadow: var(--shadow-sm);
}

.view-toggle-btn svg {
  width: 16px;
  height: 16px;
}

.limit-select-wrapper {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.limit-select {
  background-color: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  padding: 0.35rem 0.75rem;
  font-size: 0.85rem;
  cursor: pointer;
  transition: var(--transition);
}

.limit-select:hover {
  border-color: var(--accent);
}

/* ==========================================
   Vista Grid de Tarjetas de Producto
   ========================================== */
.products-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.25rem;
}

.grid-card {
  background-color: #FFFFFF;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 1rem;
  display: flex;
  flex-direction: column;
  position: relative;
  transition: var(--transition);
}

.grid-card:hover {
  box-shadow: var(--shadow-md);
  border-color: var(--accent);
}

.card-image-wrapper {
  width: 100%;
  height: 180px;
  background-color: var(--bg-secondary);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  margin-bottom: 0.75rem;
}

.card-image-wrapper img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  padding: 0.75rem;
  transition: transform 0.3s ease;
}

.grid-card:hover .card-image-wrapper img {
  transform: scale(1.06);
}

.brand-badge {
  position: absolute;
  top: 8px;
  left: 8px;
  background-color: var(--badge-bg);
  color: var(--badge-text);
  font-size: 0.7rem;
  font-weight: 600;
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  text-transform: uppercase;
}

.card-sku {
  font-size: 0.7rem;
  color: var(--text-secondary);
  opacity: 0.75;
  text-transform: uppercase;
  margin-bottom: 0.25rem;
  font-family: monospace;
}

.card-title {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.35;
  margin-bottom: 0.75rem;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  height: 2.7em;
}

.card-price-row {
  margin-top: auto;
  margin-bottom: 0.75rem;
}

.card-price {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--accent);
}

.stock-indicator {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.75rem;
  font-weight: 500;
  margin-bottom: 0.75rem;
}

.stock-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.stock-dot.in {
  background-color: var(--success);
}

.stock-dot.out {
  background-color: var(--danger);
}

.stock-text.in {
  color: var(--success);
}

.stock-text.out {
  color: var(--danger);
}

.sync-date-text {
  font-size: 0.65rem;
  color: var(--text-secondary);
  opacity: 0.6;
  margin-bottom: 0.75rem;
}

.card-actions-wrapper {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.btn-primary-cart {
  width: 100%;
  background-color: var(--accent);
  color: #FFFFFF;
  font-weight: 600;
  font-size: 0.85rem;
  padding: 0.6rem;
  border-radius: var(--radius-sm);
  cursor: pointer;
  text-align: center;
  transition: var(--transition);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.35rem;
}

.btn-primary-cart:hover {
  background-color: var(--accent-hover);
}

.btn-secondary-link {
  width: 100%;
  border: 1px solid var(--border-color);
  color: var(--text-secondary);
  font-weight: 500;
  font-size: 0.85rem;
  padding: 0.6rem;
  border-radius: var(--radius-sm);
  cursor: pointer;
  text-align: center;
  transition: var(--transition);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.25rem;
}

.btn-secondary-link:hover {
  background-color: var(--bg-secondary);
  color: var(--text-primary);
  border-color: var(--text-secondary);
}

/* ==========================================
   Vista Lista de Tarjetas de Producto
   ========================================== */
.products-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.list-card {
  background-color: #FFFFFF;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 1rem;
  display: flex;
  gap: 1.5rem;
  position: relative;
  transition: var(--transition);
}

.list-card:hover {
  box-shadow: var(--shadow-md);
  border-color: var(--accent);
}

.list-card .card-image-wrapper {
  width: 150px;
  height: 120px;
  flex-shrink: 0;
  margin-bottom: 0;
}

.list-card-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.list-card-right {
  width: 200px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  border-left: 1px solid var(--border-color);
  padding-left: 1.5rem;
  flex-shrink: 0;
}

/* Specs resumidas para vista lista */
.list-specs-container {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 0.5rem;
}

.list-spec-tag {
  background-color: var(--bg-secondary);
  border: 1px solid var(--border-color);
  font-size: 0.75rem;
  color: var(--text-secondary);
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
}

/* ==========================================
   Paginación
   ========================================== */
.pagination-container {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.35rem;
  margin-top: 2rem;
}

.pagination-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 36px;
  height: 36px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  color: var(--text-secondary);
  font-weight: 500;
  font-size: 0.9rem;
  cursor: pointer;
  transition: var(--transition);
  padding: 0 6px;
}

.pagination-btn:hover {
  background-color: var(--bg-secondary);
  color: var(--text-primary);
}

.pagination-btn.active {
  background-color: var(--accent);
  color: #FFFFFF;
  border-color: var(--accent);
}

.pagination-btn.disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.pagination-btn.dots {
  border-color: transparent;
  cursor: default;
}

.pagination-btn.dots:hover {
  background: transparent;
  color: var(--text-secondary);
}

/* Placeholder laptop SVG */
.laptop-placeholder-svg {
  width: 48px;
  height: 48px;
  color: var(--text-secondary);
  opacity: 0.6;
}

/* Estado de catálogo vacío */
.empty-catalog-state {
  grid-column: 1 / -1;
  text-align: center;
  padding: 4rem 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  color: var(--text-secondary);
  background-color: var(--bg-secondary);
  border-radius: var(--radius-md);
  border: 1px dashed var(--border-color);
}

.empty-catalog-state svg {
  width: 48px;
  height: 48px;
  opacity: 0.6;
}

/* ==========================================
   Página 2: Detalle del Producto
   ========================================== */
.breadcrumb-container {
  max-width: 1200px;
  margin: 1.5rem auto 0;
  padding: 0 1.5rem;
  width: 100%;
}

.breadcrumb-nav {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem;
  font-size: 0.8rem;
  color: var(--text-secondary);
}

.breadcrumb-nav a {
  color: var(--accent);
}

.breadcrumb-nav a:hover {
  text-decoration: underline;
}

.product-detail-layout {
  max-width: 1200px;
  margin: 1.5rem auto 3rem;
  padding: 0 1.5rem;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.detail-main-section {
  display: grid;
  grid-template-columns: 460px 1fr;
  gap: 2.5rem;
  align-items: start;
}

/* Columna Izquierda: Galería */
.gallery-column {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.main-image-wrapper {
  background-color: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  height: 400px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  cursor: zoom-in;
}

.main-image-wrapper img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  padding: 1.5rem;
  transition: transform 0.3s ease-out;
}

.main-image-wrapper:hover img {
  transform: scale(1.4);
}

.gallery-brand-badge {
  position: absolute;
  top: 16px;
  left: 16px;
  background-color: var(--accent);
  color: #FFFFFF;
  font-weight: 700;
  font-size: 0.75rem;
  text-transform: uppercase;
  padding: 0.35rem 0.75rem;
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-sm);
}

.gallery-share-btn {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background-color: #FFFFFF;
  border: 1px solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: var(--transition);
  box-shadow: var(--shadow-sm);
}

.gallery-share-btn:hover {
  background-color: var(--badge-bg);
  border-color: var(--accent);
}

.gallery-share-btn svg {
  width: 16px;
  height: 16px;
  color: var(--accent);
}

.thumbnails-row {
  display: flex;
  gap: 0.5rem;
  overflow-x: auto;
}

.thumbnail-box {
  width: 70px;
  height: 70px;
  border: 2px solid var(--accent);
  background-color: var(--bg-secondary);
  border-radius: var(--radius-sm);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
  transition: var(--transition);
}

.thumbnail-box img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  padding: 0.25rem;
}

/* Columna Derecha: Info */
.info-column {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.info-sku-label {
  font-size: 0.8rem;
  color: var(--text-secondary);
  opacity: 0.8;
  font-family: monospace;
}

.info-title {
  font-size: 1.4rem;
  font-weight: 700;
  line-height: 1.3;
}

.info-rating-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
}

.stars-container {
  display: flex;
  gap: 1px;
}

.stars-container svg {
  width: 16px;
  height: 16px;
  color: #FBBF24;
}

.reviews-link-simulated {
  color: var(--accent);
  font-weight: 500;
}

.reviews-link-simulated:hover {
  text-decoration: underline;
}

.info-prices-card {
  background-color: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.info-price-main {
  font-size: 2rem;
  font-weight: 700;
  color: var(--accent);
  line-height: 1;
}

.info-price-ref-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.9rem;
  color: var(--text-secondary);
}

.price-ref-strike {
  text-decoration: line-through;
}

.price-savings-badge {
  background-color: #FEF3C7;
  color: #D97706;
  font-size: 0.75rem;
  font-weight: 700;
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
}

.info-stock-promo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--success);
}

.info-quantity-actions-grid {
  display: flex;
  gap: 1rem;
  align-items: center;
  margin-top: 0.5rem;
}

.quantity-picker {
  display: flex;
  align-items: center;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  background-color: #FFFFFF;
  overflow: hidden;
  height: 48px;
  width: 120px;
}

.quantity-picker button {
  width: 40px;
  height: 100%;
  background-color: var(--bg-secondary);
  cursor: pointer;
  font-weight: 600;
  transition: var(--transition);
}

.quantity-picker button:hover {
  background-color: var(--border-color);
}

.quantity-picker input {
  width: 40px;
  height: 100%;
  text-align: center;
  font-weight: 600;
  font-size: 0.95rem;
}

.info-add-btn-large {
  flex: 1;
  height: 48px;
  background-color: var(--accent);
  color: #FFFFFF;
  font-weight: 700;
  border-radius: var(--radius-sm);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  transition: var(--transition);
}

.info-add-btn-large:hover {
  background-color: var(--accent-hover);
}

.info-origin-btn-outline {
  height: 48px;
  border: 1px solid var(--accent);
  color: var(--accent);
  font-weight: 600;
  border-radius: var(--radius-sm);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  transition: var(--transition);
  padding: 0 1.25rem;
}

.info-origin-btn-outline:hover {
  background-color: var(--badge-bg);
}

.divider-line {
  height: 1px;
  background-color: var(--border-color);
  margin: 0.5rem 0;
}

/* Specs rápidas */
.quick-specs-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem 1.5rem;
}

.quick-spec-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.quick-spec-item svg {
  width: 18px;
  height: 18px;
  color: var(--accent);
  flex-shrink: 0;
}

.update-date-alert {
  font-size: 0.75rem;
  color: var(--text-secondary);
  opacity: 0.8;
  font-style: italic;
  display: flex;
  align-items: center;
  gap: 0.35rem;
}

.update-date-alert svg {
  width: 14px;
  height: 14px;
}

/* ==========================================
   Tabs del Detalle de Producto
   ========================================== */
.tabs-outer-wrapper {
  margin-top: 1.5rem;
}

.tabs-headers-row {
  display: flex;
  border-bottom: 1px solid var(--border-color);
}

.tab-nav-btn {
  padding: 0.75rem 1.5rem;
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--text-secondary);
  cursor: pointer;
  position: relative;
  transition: var(--transition);
}

.tab-nav-btn:hover {
  color: var(--text-primary);
}

.tab-nav-btn.active {
  color: var(--accent);
}

.tab-nav-btn.active::after {
  content: "";
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 100%;
  height: 2px;
  background-color: var(--accent);
}

.tabs-content-box {
  padding: 1.5rem 0;
}

.tab-panel {
  display: none;
}

.tab-panel.active {
  display: block;
}

/* Tab 1: Especificaciones Completas */
.specs-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.85rem;
}

.specs-table tr {
  border-bottom: 1px solid var(--border-color);
}

.specs-table tr:nth-child(even) {
  background-color: var(--bg-secondary);
}

.specs-table td {
  padding: 0.75rem 1rem;
}

.specs-table td.spec-name {
  font-weight: 600;
  color: var(--text-primary);
  width: 25%;
}

.specs-table td.spec-val {
  color: var(--text-secondary);
}

/* Tab 2: Reseñas simuladas */
.reviews-grid-tab {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 3rem;
  align-items: start;
}

.reviews-summary-column {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.reviews-summary-score {
  font-size: 3rem;
  font-weight: 700;
  line-height: 1;
}

.star-bars-list {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.star-bar-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  color: var(--text-secondary);
}

.star-bar-track {
  flex: 1;
  height: 6px;
  background-color: var(--border-color);
  border-radius: 3px;
  overflow: hidden;
}

.star-bar-fill {
  height: 100%;
  background-color: #FBBF24;
}

.star-bar-percent {
  width: 30px;
  text-align: right;
}

.reviews-items-list {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.review-item-card {
  border-bottom: 1px solid var(--border-color);
  padding-bottom: 1.25rem;
}

.review-item-card:last-child {
  border-bottom: none;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0.5rem;
}

.review-author-info {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.review-avatar-circle {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background-color: var(--badge-bg);
  color: var(--accent);
  font-weight: 600;
  font-size: 0.9rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.review-author-name {
  font-weight: 600;
  font-size: 0.85rem;
}

.review-item-date {
  font-size: 0.75rem;
  color: var(--text-secondary);
}

.review-item-text {
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.45;
}

.btn-reviews-more-sim {
  align-self: flex-start;
  padding: 0.6rem 1.25rem;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
}

.btn-reviews-more-sim:hover {
  background-color: var(--bg-secondary);
}

/* Tab 3: Envío y Garantía */
.shipping-tab-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
}

.shipping-info-card {
  background-color: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 1.25rem;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
}

.shipping-info-card svg {
  width: 32px;
  height: 32px;
  color: var(--accent);
}

.shipping-card-title {
  font-weight: 700;
  font-size: 0.9rem;
}

.shipping-card-desc {
  font-size: 0.8rem;
  color: var(--text-secondary);
  line-height: 1.4;
}

/* ==========================================
   Sección: Productos Relacionados
   ========================================== */
.related-products-section {
  border-top: 1px solid var(--border-color);
  padding-top: 2rem;
  margin-top: 2rem;
}

.related-title {
  font-size: 1.2rem;
  font-weight: 700;
  margin-bottom: 1.25rem;
}

.related-scroll-wrapper {
  overflow-x: auto;
  padding-bottom: 1rem;
}

.related-grid {
  display: grid;
  grid-template-columns: repeat(8, 260px);
  gap: 1rem;
  width: max-content;
}

/* ==========================================
   Drawer Lateral del Carrito
   ========================================== */
.cart-drawer-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(2px);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: var(--transition);
}

.cart-drawer-overlay.open {
  opacity: 1;
  visibility: visible;
}

.cart-drawer {
  position: fixed;
  top: 0;
  right: 0;
  width: 100%;
  max-width: 420px;
  height: 100vh;
  background-color: #FFFFFF;
  z-index: 201;
  box-shadow: var(--shadow-lg);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.cart-drawer.open {
  transform: translateX(0);
}

.cart-drawer-header {
  padding: 1.25rem;
  border-bottom: 1px solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cart-drawer-title {
  font-weight: 700;
  font-size: 1.1rem;
}

.cart-drawer-close-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition);
}

.cart-drawer-close-btn:hover {
  background-color: var(--bg-secondary);
}

.cart-drawer-close-btn svg {
  width: 18px;
  height: 18px;
  color: var(--text-secondary);
}

.cart-drawer-body {
  flex: 1;
  overflow-y: auto;
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

/* Item del Carrito */
.cart-item-card {
  display: flex;
  gap: 0.75rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--border-color);
}

.cart-item-img {
  width: 70px;
  height: 70px;
  background-color: var(--bg-secondary);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cart-item-img img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  padding: 0.25rem;
}

.cart-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.cart-item-title {
  font-size: 0.8rem;
  font-weight: 600;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cart-item-sku {
  font-size: 0.7rem;
  color: var(--text-secondary);
  opacity: 0.7;
  font-family: monospace;
}

.cart-item-price {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--accent);
}

.cart-item-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 0.5rem;
}

.cart-item-quantity {
  display: flex;
  align-items: center;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  overflow: hidden;
  height: 28px;
}

.cart-item-quantity button {
  width: 24px;
  height: 100%;
  background-color: var(--bg-secondary);
  cursor: pointer;
  font-weight: 600;
  font-size: 0.8rem;
}

.cart-item-quantity input {
  width: 28px;
  height: 100%;
  text-align: center;
  font-size: 0.8rem;
  font-weight: 600;
}

.cart-item-remove-btn {
  cursor: pointer;
  color: var(--danger);
  font-size: 0.75rem;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 0.25rem;
  transition: var(--transition);
}

.cart-item-remove-btn:hover {
  opacity: 0.8;
}

.cart-item-remove-btn svg {
  width: 14px;
  height: 14px;
}

/* Estado de Carrito Vacío */
.empty-cart-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  height: 250px;
  text-align: center;
  color: var(--text-secondary);
}

.empty-cart-state svg {
  width: 44px;
  height: 44px;
  opacity: 0.6;
}

.cart-drawer-footer {
  padding: 1.25rem;
  border-top: 1px solid var(--border-color);
  background-color: var(--bg-secondary);
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.cart-summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 0.95rem;
}

.cart-subtotal-val {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--accent);
}

.cart-shipping-notice {
  font-size: 0.75rem;
  color: var(--text-secondary);
  text-align: center;
  opacity: 0.85;
}

.btn-checkout-drawer {
  width: 100%;
  background-color: var(--accent);
  color: #FFFFFF;
  padding: 0.85rem;
  font-weight: 700;
  border-radius: var(--radius-sm);
  cursor: pointer;
  text-align: center;
  transition: var(--transition);
}

.btn-checkout-drawer:hover {
  background-color: var(--accent-hover);
}

.btn-close-drawer {
  width: 100%;
  border: 1px solid var(--border-color);
  background-color: #FFFFFF;
  color: var(--text-secondary);
  padding: 0.85rem;
  font-weight: 600;
  border-radius: var(--radius-sm);
  cursor: pointer;
  text-align: center;
  transition: var(--transition);
}

.btn-close-drawer:hover {
  background-color: var(--bg-secondary);
  color: var(--text-primary);
}

/* ==========================================
   Toast Notification Popups (Copiar URL, etc)
   ========================================== */
.toast-container {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(100px);
  background-color: #111111;
  color: #FFFFFF;
  padding: 0.75rem 1.5rem;
  border-radius: 50px;
  font-size: 0.85rem;
  font-weight: 600;
  box-shadow: var(--shadow-lg);
  z-index: 300;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  pointer-events: none;
  opacity: 0;
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.3s ease;
}

.toast-container.show {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
}

.toast-container svg {
  width: 16px;
  height: 16px;
  color: var(--success);
}

/* ==========================================
   Footer Común
   ========================================== */
footer {
  background-color: var(--bg-secondary);
  border-top: 1px solid var(--border-color);
  padding: 3rem 1.5rem 1.5rem;
  margin-top: auto;
}

.footer-container {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 2fr 1fr 1.5fr;
  gap: 3rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--border-color);
}

.footer-col {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.footer-col h4 {
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--text-primary);
}

.footer-col p {
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

.footer-links-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.footer-links-list a:hover {
  color: var(--accent);
}

.footer-bottom {
  max-width: 1200px;
  margin: 1.5rem auto 0;
  text-align: center;
  font-size: 0.8rem;
  color: var(--text-secondary);
  opacity: 0.8;
}

/* ==========================================
   ANIMACIONES Y EFECTOS
   ========================================== */
@keyframes pulse {

  0%,
  100% {
    opacity: 0.4;
  }

  50% {
    opacity: 1;
  }
}

@keyframes shake {

  0%,
  100% {
    transform: translateX(0);
  }

  25% {
    transform: translateX(-4px);
  }

  75% {
    transform: translateX(4px);
  }
}

.animate-shake {
  animation: shake 0.3s ease-in-out;
}

/* ==========================================
   Diseño Oscuro Especial del Admin Panel
   ========================================== */
body.admin-theme {
  background-color: var(--bg-app);
  color: var(--color-text-primary);
}

body.admin-theme header {
  border-bottom: 1px solid var(--border-color);
}

body.admin-theme .admin-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 1.5rem;
}

body.admin-theme h1,
body.admin-theme h2,
body.admin-theme h3 {
  color: var(--color-text-primary);
}

body.admin-theme .admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
}

body.admin-theme .admin-btn-back {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--color-accent);
  font-weight: 600;
  font-size: 0.9rem;
}

body.admin-theme .admin-panel-hero {
  background-color: var(--bg-surface);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 2rem;
  margin-bottom: 2rem;
}

body.admin-theme .admin-hero-title {
  font-size: 1.6rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

body.admin-theme .admin-hero-desc {
  color: var(--color-text-secondary);
  font-size: 0.9rem;
  margin-bottom: 1.5rem;
}

body.admin-theme .admin-controls-panel {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  background-color: var(--bg-app);
  padding: 1rem;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border-color);
}

body.admin-theme .admin-btn-scrape {
  background-color: var(--color-accent);
  color: #052e16;
  font-weight: 700;
  padding: 0.65rem 1.5rem;
  border-radius: var(--radius-sm);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: var(--transition);
}

body.admin-theme .admin-btn-scrape:hover {
  background-color: var(--color-accent-hover);
}

body.admin-theme .admin-indicator-box {
  display: none;
  background-color: rgba(6, 182, 212, 0.08);
  border: 1px solid var(--color-cyan);
  border-radius: var(--radius-sm);
  padding: 1rem;
  margin-top: 1rem;
  align-items: center;
  gap: 1rem;
}

body.admin-theme .htmx-request.admin-indicator-box {
  display: flex;
}

body.admin-theme .admin-spinner {
  width: 24px;
  height: 24px;
  border: 2px solid rgba(6, 182, 212, 0.1);
  border-top-color: var(--color-cyan);
  border-radius: 50%;
  animation: spin 0.8s infinite linear;
}

body.admin-theme .admin-table-section {
  background-color: var(--bg-surface);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 1.5rem;
}

body.admin-theme .admin-table-title {
  font-size: 1.15rem;
  font-weight: 600;
  margin-bottom: 1rem;
}

body.admin-theme .admin-table {
  width: 100%;
