<file path="scraper.js">
const { chromium } = require('playwright-extra');
const stealth = require('puppeteer-extra-plugin-stealth')();
const { upsertProduct } = require('./database');

// Registrar el plugin de stealth en playwright-extra
chromium.use(stealth);

/**
 * Limpia el texto del precio y lo convierte a número flotante.
 * Soporta formatos como "$1,249.99" y "$1.249,99", y limpia textos concatenados como "Comprar".
 * @param {string} priceText - El texto del precio a limpiar.
 * @returns {number} El precio como número flotante.
 */
function cleanPrice(priceText) {
  if (!priceText) return 0;

  // Eliminar símbolos de moneda, texto ("Comprar", etc.) y espacios en blanco
  // Manteniendo únicamente números, puntos y comas
  let clean = priceText.replace(/[^0-9.,]/g, '').trim();

  // Detectar si el formato es europeo/latinoamericano (1.249,99) o americano (1,249.99)
  const lastComma = clean.lastIndexOf(',');
  const lastDot = clean.lastIndexOf('.');

  if (lastComma > lastDot) {
    // Formato "1.249,99" -> Eliminar puntos y reemplazar coma por punto decimal
    clean = clean.replace(/\./g, '').replace(',', '.');
  } else if (lastDot > lastComma) {
    // Formato "1,249.99" -> Eliminar comas
    clean = clean.replace(/,/g, '');
  } else {
    // Formato simple "1249" o "1249,99" sin otros separadores
    clean = clean.replace(',', '.');
  }

  const parsed = parseFloat(clean);
  return isNaN(parsed) ? 0 : parsed;
}

/**
 * Función principal de scraping
 * Inicia el navegador Chromium en modo stealth, navega a la URL de Next.js y procesa los productos
 * @returns {Promise<number>} Número de productos raspados y guardados con éxito
 */
async function scrapeLaptops() {
  console.log('Iniciando navegador Chromium en modo Stealth...');
  const browser = await chromium.launch({
    headless: true,
    args: [
      '--no-sandbox',
      '--disable-setuid-sandbox',
      '--disable-blink-features=AutomationControlled'
    ]
  });

  const context = await browser.newContext({
    userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
    viewport: { width: 1280, height: 1000 }
  });

  const page = await context.newPage();

  try {
    const url = 'https://tecnomegastore.ec/category/1/3N003-pc-laptop-portatil-notebook';
    console.log(`Navegando a la URL: ${url}`);

    // Esperar a que la red esté completamente inactiva (networkidle) para garantizar la hidratación de React/Next
    await page.goto(url, { waitUntil: 'networkidle', timeout: 60000 });

    console.log('Esperando estabilización de renderizado dinámico...');
    // Esperar 5 segundos adicionales para asegurar renderizado completo
    await page.waitForTimeout(5000);

    console.log('Extrayendo información de los productos...');
    // Extraer los datos de la página
    const productsData = await page.evaluate(() => {
      // Obtener todos los enlaces a productos que tengan el parámetro 'code' (SKU)
      const productLinks = Array.from(document.querySelectorAll('a'))
        .filter(a => a.href && a.href.includes('/product/') && a.href.includes('code='));

      const results = [];

      productLinks.forEach(link => {
        const urlStr = link.href;
        let sku = '';
        try {
          const urlObj = new URL(urlStr);
          sku = urlObj.searchParams.get('code') || '';
        } catch (e) {
          const match = urlStr.match(/[?&]code=([^&]+)/);
          if (match) sku = match[1];
        }

        const nombre = link.innerText.trim();

        // Encontrar la tarjeta contenedora (.bg-white)
        const card = link.closest('.bg-white') || link.parentElement?.parentElement;

        let precioTexto = '';
        let imagenUrl = '';
        if (card) {
          // Extraer la URL de la imagen del producto
          const imgEl = card.querySelector('img');
          imagenUrl = imgEl ? imgEl.src : '';

          // Buscar cualquier elemento que contenga el símbolo de dólar $
          const allElements = Array.from(card.querySelectorAll('*'));
          const priceElement = allElements.find(el => {
            const txt = el.textContent.trim();
            return txt.startsWith('$') && /\d/.test(txt);
          });

          if (priceElement) {
            precioTexto = priceElement.textContent.trim();
          } else {
            const matchPrice = card.innerText.match(/\$\s*([0-9.,]+)/);
            if (matchPrice) {
              precioTexto = matchPrice[0];
            }
          }
        }

        // Si tenemos SKU y nombre válido, agregamos al resultado preliminar
        if (sku && nombre && precioTexto) {
          results.push({ sku, nombre, precioTexto, imagenUrl });
        }
      });

      return results;
    });

    console.log(`Se encontraron ${productsData.length} productos. Procesando y guardando en JSON DB...`);

    let savedCount = 0;
    for (const item of productsData) {
      const precioCosto = cleanPrice(item.precioTexto);

      // Solo guardar productos con precio válido
      if (precioCosto > 0) {
        upsertProduct(item.sku, item.nombre, precioCosto, item.imagenUrl);
        savedCount++;
      }
    }

    console.log(`Scraping finalizado. ${savedCount} productos fueron agregados o actualizados en la base de datos.`);
    return savedCount;

  } catch (error) {
    console.error('Error durante el proceso de scraping:', error);
    throw error;
  } finally {
    // Asegurar que el navegador se cierre para liberar recursos
    await browser.close();
    console.log('Navegador cerrado.');
  }
}

module.exports = {
  scrapeLaptops
};
</file>

<file path="server.js">
const express = require('express');
const path = require('path');
const { getAllProducts } = require('./database');
const { scrapeLaptops } = require('./scraper');

const app = express();
const PORT = process.env.PORT || 3000;

// Configurar Express para servir los archivos estáticos del frontend desde la carpeta 'public'
app.use(express.static(path.join(__dirname, 'public')));
app.use(express.json());

/**
 * Helper para formatear valores numéricos a dólares estadounidenses (USD)
 * @param {number} value - El número a formatear
 * @returns {string} Texto formateado ej. "$1,249.99"
 */
function formatCurrency(value) {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD'
  }).format(value);
}

/**
 * Helper para renderizar los productos en formato de tarjetas de catálogo HTML (Grid)
 * @param {Array} products - Lista de productos obtenidos de la base de datos
 * @returns {string} Fragmento HTML con las tarjetas o estado vacío
 */
function renderProductCards(products) {
  if (!products || products.length === 0) {
    return `
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="empty-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m8.25 3v6.75m0 0l-3-3m3 3l3-3M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
        </svg>
        <p>El catálogo local está vacío. Presiona "Actualizar Catálogo" para iniciar el scraping en tiempo real.</p>
      </div>
    `;
  }

  return products.map(p => {
    // Generar un enlace real de búsqueda o directo a Tecnomegastore para el SKU
    const productUrl = `https://tecnomegastore.ec/product/laptop?code=${p.sku}`;
    
    // Obtener solo la fecha (YYYY-MM-DD) del timestamp de actualización
    const dateOnly = p.ultima_actualizacion ? p.ultima_actualizacion.split(' ')[0] : '';

    return `
      <div class="product-card animate-fade-in">
        <div class="product-card-header">
          <span class="badge-sku">${p.sku}</span>
          <span class="sync-date">${dateOnly}</span>
        </div>
        
        <!-- Imagen Real del Producto (con Fallback a SVG) -->
        <div class="product-image-container">
          ${p.imagen_url ? `
            <img src="${p.imagen_url}" alt="${p.nombre}" class="product-image" loading="lazy" />
          ` : `
            <div class="product-image-placeholder" style="border: none; margin: 0; background: transparent; height: 100%; width: 100%;">
              <svg class="laptop-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" />
              </svg>
            </div>
          `}
        </div>
        
        <div class="product-info">
          <h3 class="product-title" title="${p.nombre}">${p.nombre}</h3>
          
          <div class="price-section">
            <div class="price-group">
              <span class="price-label">Precio</span>
              <span class="price-val price-sell">${formatCurrency(p.precio !== undefined ? p.precio : p.precio_costo)}</span>
            </div>
          </div>
        </div>
        
        <div class="product-actions">
          <a href="${productUrl}" target="_blank" rel="noopener" class="btn-view-product">
            Ver en tienda
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </a>
        </div>
      </div>
    `;
  }).join('');
}

// Ruta GET / - Sirve public/index.html
app.get('/', (req, res) => {
  res.sendFile(path.join(__dirname, 'public', 'index.html'));
});

// Ruta GET /product.html - Sirve public/product.html
app.get('/product.html', (req, res) => {
  res.sendFile(path.join(__dirname, 'public', 'product.html'));
});

// Ruta GET /admin - Valida ?key=admin2026, sirve public/admin.html o redirige a /
app.get('/admin', (req, res) => {
  const { key } = req.query;
  if (key === 'admin2026') {
    res.sendFile(path.join(__dirname, 'public', 'admin.html'));
  } else {
    res.redirect('/');
  }
});

// Ruta GET /api/productos/json - NUEVA: devuelve todos los productos como JSON puro
app.get('/api/productos/json', (req, res) => {
  try {
    const products = getAllProducts();
    res.json(products);
  } catch (error) {
    console.error('Error al obtener productos JSON:', error);
    res.status(500).json({ error: error.message });
  }
});

// Ruta GET /api/producto/:sku - NUEVA: devuelve un producto específico por SKU como JSON
app.get('/api/producto/:sku', (req, res) => {
  try {
    const { sku } = req.params;
    const products = getAllProducts();
    const product = products.find(p => p.sku === sku);
    if (product) {
      res.json(product);
    } else {
      res.status(404).json({ error: 'Producto no encontrado' });
    }
  } catch (error) {
    console.error('Error al obtener producto por SKU:', error);
    res.status(500).json({ error: error.message });
  }
});

// Ruta GET /api/productos/marcas - NUEVA: devuelve lista de marcas únicas con conteo
app.get('/api/productos/marcas', (req, res) => {
  try {
    const products = getAllProducts();
    const brandCounts = {};
    const brandKeywords = ['Apple', 'HP', 'Lenovo', 'Dell', 'Dynabook', 'Quasad', 'Samsung', 'Asus', 'Acer', 'MSI'];

    // Inicializar marcas con 0
    brandKeywords.forEach(brand => {
      brandCounts[brand] = 0;
    });
    brandCounts['Otros'] = 0;

    products.forEach(p => {
      const name = p.nombre || '';
      let matchedBrand = 'Otros';
      for (const brand of brandKeywords) {
        if (name.toLowerCase().includes(brand.toLowerCase())) {
          matchedBrand = brand;
          break;
        }
      }
      brandCounts[matchedBrand] = (brandCounts[matchedBrand] || 0) + 1;
    });

    // Filtrar solo las marcas que tienen productos para no mostrar categorías vacías
    const result = Object.keys(brandCounts)
      .map(brand => ({ brand, count: brandCounts[brand] }))
      .filter(item => item.count > 0);

    res.json(result);
  } catch (error) {
    console.error('Error al obtener marcas:', error);
    res.status(500).json({ error: error.message });
  }
});

// Ruta GET /api/productos - Devuelve las tarjetas del catálogo (para panel admin u otros)

app.get('/api/productos', (req, res) => {
  try {
    const products = getAllProducts();
    const html = renderProductCards(products);
    res.send(html);
  } catch (error) {
    console.error('Error al obtener productos:', error);
    res.status(500).send(`
      <div class="error-alert-wrapper animate-shake">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="alert-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <div class="error-details">
          <strong>Error al cargar catálogo:</strong> ${error.message}
        </div>
      </div>
    `);
  }
});

// Ruta POST /api/scrape - Ejecuta el scraping y devuelve las tarjetas actualizadas
app.post('/api/scrape', async (req, res) => {
  try {
    console.log('Iniciando proceso de scraping a petición del usuario...');
    const totalScraped = await scrapeLaptops();
    console.log(`Se procesaron ${totalScraped} productos con éxito.`);
    
    // Obtener los productos actualizados de la base de datos
    const products = getAllProducts();
    const html = renderProductCards(products);
    res.send(html);
  } catch (error) {
    console.error('Error al ejecutar el scraper:', error);
    res.status(500).send(`
      <div class="error-alert-wrapper animate-shake">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="alert-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <div class="error-details">
          <strong>Error de Scraping:</strong> ${error.message || 'No se pudo conectar al sitio web.'}
          <br><small>Por favor verifica tu conexión a internet o el estado de Tecnomegastore.</small>
        </div>
      </div>
    `);
  }
});

// --- PLANIFICADOR DE ACTUALIZACIÓN AUTOMÁTICA EN SEGUNDO PLANO ---
const UN_HORA = 60 * 60 * 1000; // 60 minutos en milisegundos

setInterval(async () => {
  console.log('🕒 [Automatización] Iniciando actualización rutinaria de laptops en segundo plano...');
  try {
    const totalScraped = await scrapeLaptops();
    console.log(`🕒 [Automatización] Actualización exitosa. ${totalScraped} productos sincronizados.`);
  } catch (error) {
    console.error('❌ [Automatización] Fallo en la sincronización periódica:', error.message);
  }
}, UN_HORA);

// Iniciar el servidor
app.listen(PORT, () => {
  console.log(`\n======================================================`);
  console.log(`🚀 Servidor iniciado en http://localhost:${PORT}`);
  console.log(`📂 Servidor estático apuntando a /public`);
  console.log(`======================================================\n`);
});
