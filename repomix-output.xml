              </svg>
            </a>
          </div>

          <!-- Botón HTMX -->
          <button id="scrape-btn" class="admin-btn-scrape" hx-post="/api/scrape" hx-target="#tabla-productos" hx-indicator="#loading-indicator">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
            Actualizar Catálogo
          </button>
        </div>

        <!-- Indicador de Carga HTMX -->
        <div id="loading-indicator" class="admin-indicator-box htmx-indicator">
          <div class="admin-spinner"></div>
          <div>
            <div style="font-size:0.9rem;font-weight:600;color:var(--color-text-primary);">Raspando datos en tiempo real...</div>
            <div style="font-size:0.75rem;color:var(--color-text-secondary);">
              Playwright Chromium Stealth está analizando el catálogo de laptops de Tecnomegastore de forma segura. Por favor, espera.
            </div>
          </div>
        </div>
      </section>

      <!-- Tabla de los Últimos 5 Productos Sincronizados -->
      <section class="admin-table-section" style="margin-bottom:2rem;">
        <h2 class="admin-table-title">Últimos 5 Productos Sincronizados</h2>
