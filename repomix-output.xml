        </svg>
        <span style="color:#ffffff;">NoteStore <span class="logo-accent">Ecuador</span></span>
      </div>
    </header>

    <main>
      <!-- Hero Panel de Control Scraper -->
      <section class="admin-panel-hero">
        <h1 class="admin-hero-title">Control de Raspado y Catálogo</h1>
        <p class="admin-hero-desc">
          Este panel interactivo permite gestionar el scraping automatizado de la sección de laptops en
          <strong>Tecnomegastore</strong>.
          La información es extraída de forma asíncrona mediante agentes y sincronizada directamente en nuestra base de datos local JSON.
        </p>

        <!-- PANEL DE ACCIONES -->
        <div class="admin-controls-panel">
          <div style="display:flex;flex-direction:column;gap:0.2rem;">
            <span style="font-size:0.7rem;text-transform:uppercase;letter-spacing:1px;color:var(--color-text-muted);font-weight:600;">Sitio Destino (E-Commerce)</span>
            <a href="https://tecnomegastore.ec/category/1/3N003-pc-laptop-portatil-notebook" target="_blank" rel="noopener" style="color:var(--color-cyan);font-weight:500;font-size:0.9rem;display:flex;align-items:center;gap:0.35rem;">
